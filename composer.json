{
	"name": "erhaweb/klaro-consent-manager",
	"type": "typo3-cms-extension",
	"description": "Klaro! Consent Manager - Functionally complete, flexible TYPO3 integration of Klaro! Consent Management by KIProtect GmbH, a powerful tool that protects your visitors' privacy and data.",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2 <8.6",
		"ext-pdo": "*",
		"typo3/cms-core": "^13.4 || ^14.3"
	},
	"require-dev": {
		"a9f/typo3-fractor": "^0.5",
		"phpunit/phpunit": "^11.5",
		"roave/security-advisories": "dev-latest",
		"ssch/typo3-rector": "^3.11",
		"typo3/cms-fluid-styled-content": "^13.4 || ^14.3",
		"typo3/cms-install": "^13.4 || ^14.3",
		"typo3/testing-framework": "^9.0"
	},
	"authors": [
		{
			"name": "Eric Harrer",
			"role": "Developer",
			"email": "info@eric-harrer.de",
			"homepage": "https://www.eric-harrer.de"
		}
	],
	"keywords": [
		"TYPO3",
		"extension",
		"Consent Manager",
		"Klaro",
		"GDPR"
	],
	"homepage": "https://extensions.typo3.org/extension/klaro_consent_manager",
	"support": {
		"source": "https://github.com/ErHaWeb/klaro_consent_manager",
		"issues": "https://github.com/ErHaWeb/klaro_consent_manager/issues",
		"docs": "https://docs.typo3.org/p/erhaweb/klaro-consent-manager/main/en-us/"
	},
	"funding": [
		{
			"type": "other",
			"url": "https://www.paypal.com/paypalme/ebode"
		}
	],
	"autoload": {
		"psr-4": {
			"ErHaWeb\\KlaroConsentManager\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"ErHaWeb\\KlaroConsentManager\\Tests\\": "Tests/"
		}
	},
	"replace": {
		"typo3-ter/klaro-consent-manager": "self.version"
	},
	"config": {
		"allow-plugins": {
			"a9f/fractor-extension-installer": true,
			"sbuerk/typo3-cmscomposerinstallers-testingframework-bridge": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"bin-dir": ".Build/bin",
		"lock": false,
		"preferred-install": {
			"*": "dist"
		},
		"sort-packages": true,
		"vendor-dir": ".Build/vendor"
	},
	"extra": {
		"typo3/cms": {
			"web-dir": ".Build/Web",
			"extension-key": "klaro_consent_manager",
			"version": "3.0.4",
			"Package": {
				"providesPackages": {}
			}
		}
	}
}
